  "entries": [
    {
      "id": "thermal.equilibrium_time",
      "domain": "construction.buildings",
      "type": "formula",
      "title": "Mass concrete pour equilibrium time",
      "statement": "Time for a mass concrete pour of half-thickness X (m) to reach thermal equilibrium with ambient. Result is hours; the constant 168 carries the hour unit while (X / 1.5) is dimensionless (meter/meter).",
      "expression": "168 * (X / 1.5)**2",
      "variables": {
        "X": {"unit": "meter", "desc": "Half-thickness of the pour"}
      },
      "thresholds": {"unit": "hour"},
      "applicability": {
        "applies_to": ["construction.buildings", "construction.concrete"],
        "region_specific": null,
        "project_specific": null,
        "standards_cross_ref": []
      },
      "remediation": [],
      "provenance": {
        "source": "SMGTC552 part 2",
        "project": "Landmark Tower Abu Dhabi (CCC)",
        "confidence": "site_experience",
        "verified_against_standard": false
      },
      "credibility_tier": 3,
      "needs_review": false
    },
    {
      "id": "earthworks.swelling_factor",
      "domain": "construction.roads",
      "type": "formula",
      "title": "Earthworks swelling factor from Proctor density and compaction",
      "statement": "Swelling factor = (Proctor density A x Compaction factor C) / Loose density B. Reference table sub-base row: A=2.18, B=1.6, C=96, expected D=1.31. Unit convention note: the source table treats C as a percentage (96 means 96%); applying the formula with raw C=96 reproduces 130.8 rather than 1.31. To match the published 1.31 use C as a decimal (0.96). The loader returns the raw formula result; the caller picks the convention.",
      "expression": "(A * C) / B",
      "variables": {
        "A": {"unit": "ton/meter**3", "desc": "Modified Proctor density"},
        "B": {"unit": "ton/meter**3", "desc": "Loose density"},
        "C": {"unit": "dimensionless", "desc": "Compaction factor (percent, 0-100 scale used as raw number)"}
      },
      "thresholds": {"unit": "dimensionless"},
      "applicability": {
        "applies_to": ["construction.roads"],
        "region_specific": null,
        "project_specific": null,
        "standards_cross_ref": ["AASHTO T 180-93"]
      },
      "remediation": [],
      "provenance": {
        "source": "Message_from_MGTC55234 sect 2",
        "project": "Roads / earthworks reference binder",
        "confidence": "site_experience",
        "verified_against_standard": "AASHTO T 180-93 (Modified Proctor)"
      },
      "credibility_tier": 3,
      "needs_review": false
    },
    {
      "id": "procurement.tender_lifecycle",
      "domain": "construction.procurement",
      "type": "workflow",
      "title": "Construction tender lifecycle",
      "statement": "Job Requisition -> Sole Source justification (optional) -> Request for Authority to Tender (RAT) -> RFP issue -> Tender queries -> Tender Analysis (RAP) -> Preferred Tenderer -> BAFO -> Award.",
      "expression": null,
      "variables": {},
      "thresholds": {},
      "states": [
        "JOB_REQUISITION",
        "SOLE_SOURCE_REVIEW",
        "RAT_REQUESTED",
        "RAT_ISSUED",
        "RFP_ISSUED",
        "TENDER_QUERIES",
        "TENDER_ANALYSIS",
        "PREFERRED_TENDERER",
        "BAFO",
        "AWARDED"
      ],
      "transitions": [
        {"from": "JOB_REQUISITION", "to": "SOLE_SOURCE_REVIEW", "guard": "context.sole_source == True"},
        {"from": "JOB_REQUISITION", "to": "RAT_REQUESTED", "guard": "context.sole_source != True"},
        {"from": "SOLE_SOURCE_REVIEW", "to": "RAT_REQUESTED", "guard": "context.sole_source_signed_by_estimator and context.sole_source_signed_by_vp_pm and context.sole_source_signed_by_contracts_mgr"},
        {"from": "RAT_REQUESTED", "to": "RAT_ISSUED", "guard": "context.rat_authority_approved == True"},
        {"from": "RAT_ISSUED", "to": "RFP_ISSUED", "guard": "context.rat_number is not None"},
        {"from": "RFP_ISSUED", "to": "TENDER_QUERIES", "guard": "True"},
        {"from": "TENDER_QUERIES", "to": "TENDER_ANALYSIS", "guard": "context.tender_queries_closed == True"},
        {"from": "TENDER_ANALYSIS", "to": "PREFERRED_TENDERER", "guard": "context.evaluation_report_signed"},
        {"from": "PREFERRED_TENDERER", "to": "BAFO", "guard": "True"},
        {"from": "BAFO", "to": "AWARDED", "guard": "context.award_recommendation_letter_issued"}
      ],
      "required_documents": [
        "JR_TEM-601",
        "SSJ_TEM-602",
        "RAT",
        "RFP_TEM-613",
        "TenderEvaluationReport_TEM-624",
        "AwardRecommendationLetter_TEM-625"
      ],
      "approval_roles": [
        "Estimator",
        "VP_Project_Management",
        "Contracts_Manager",
        "Tender_Analysis_Committee",
        "Project_Director"
      ],
      "applicability": {
        "applies_to": ["construction.procurement"],
        "region_specific": null,
        "project_specific": null,
        "standards_cross_ref": ["PRC-601", "PRC-602", "PRC-603", "PRC-604"]
      },
      "remediation": [],
      "provenance": {
        "source": "PRC-601 through PRC-604",
        "project": "Dubai Parks and Resorts",
        "confidence": "controlled_document",
        "verified_against_standard": "PRC procedures"
      },
      "credibility_tier": 4,
      "needs_review": false
    }
  ]
}
