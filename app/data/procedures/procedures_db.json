{
  "version": "1.0",
  "description": "Industry-standard construction procedure knowledge base for platform validation and workflow logic. Codes (PRC-301..PRC-606, TEM-501..TEM-510) are the platform's internal procedure scheme, applicable across construction programmes.",

  "procedures": {

    "PRC-301": {
      "title": "Request for Information",
      "category": "project_controls",
      "purpose": "Control and resolve technical enquiries from Prime Contractor",
      "document_prefix": "RFI",
      "document_format": "RFI-{4d}",
      "roles": {
        "authorizer": "Programme Director",
        "initiator": "Prime Contractor",
        "responder": "Delivery Manager",
        "logger": "Document Controller"
      },
      "required_fields": ["rfi_number", "subject", "technical_query", "required_by_date", "response", "closure_date"],
      "statuses": ["OPEN", "RESPONDED", "CLOSED", "OVERDUE"],
      "rules": [
        "RFI is a technical enquiry only - NOT a design change request",
        "Every RFI must be logged in the Document Control System",
        "Response must be factual"
      ]
    },

    "PRC-302": {
      "title": "Risk Management",
      "category": "project_controls",
      "purpose": "Identify, record, and manage programme and project risks",
      "document_prefix": "RISK",
      "roles": {
        "authorizer": "Project Director",
        "owner": "Delivery Manager",
        "programme_risk": "PMC Head Project Controls",
        "cost_risk": "Chief Cost Manager",
        "register_maintainer": "Planning Managers"
      },
      "risk_format": "If [condition] Then [impact]",
      "scoring": {
        "probability_scale": [1, 2, 3, 4, 5],
        "impact_scale": [1, 2, 3, 4, 5],
        "score_formula": "probability * impact",
        "thresholds": {"green": [1, 4], "amber": [5, 9], "red": [10, 25]}
      },
      "impact_categories": ["Cost", "Time", "Quality", "Safety", "Reputation"],
      "review_cadence": "Monthly with client",
      "system": "PMWeb Risk Register"
    },

    "PRC-303": {
      "title": "Work Package Control",
      "category": "project_controls",
      "purpose": "Track and control work packages",
      "document_prefix": "WP",
      "template": "TEM-303",
      "required_fields": ["wp_number", "description", "planned_start", "actual_start", "planned_completion", "actual_completion", "percent_complete", "responsible_party"],
      "statuses": ["NOT_STARTED", "IN_PROGRESS", "COMPLETE", "OVERDUE", "ON_HOLD"]
    },

    "PRC-401": {
      "title": "Project Quality Assurance Audit",
      "category": "quality",
      "purpose": "PMC performs QA audits on Consultants and Contractors QA/QC Programs",
      "cadence": "As scheduled per audit plan",
      "finding_severity": ["Critical", "Major", "Minor", "Observation"],
      "auto_ncr_trigger": ["Critical", "Major"],
      "roles": {
        "process_owner": "PMC QA/QC Manager / PQR",
        "approver": "Employer's Representative",
        "participant_signatory": "PMC Project Director",
        "informed": "PMC Delivery Manager / Concerned Manager / Engineer"
      }
    },

    "PRC-402": {
      "title": "Construction Non-Conformance Reporting",
      "category": "quality",
      "purpose": "Disposition of Contractor NCRs",
      "document_prefix": "NCR",
      "document_format": "NCR-{YYYY}-{3d}",
      "ncr_types": {
        "physical": "Dimension or material deviation from specifications/drawings",
        "documentary": "Failure to provide test results or quality records"
      },
      "dispositions": {
        "USE_AS_IS": "Non-conformance acceptable without repair",
        "REPAIR": "Bring into conformance by rework",
        "REJECT": "Remove and replace",
        "CONCESSION": "Waiver from Employer required"
      },
      "roles": {
        "initiator": "Supervision Consultant (Engineer)",
        "signatory": ["PMC Delivery/Construction Manager", "Supervision Consultant"],
        "approver": "Employer's Representative",
        "action": "Contractor",
        "participant": ["PMC Project QA/QC Manager"],
        "informed": ["PMC Contracts Manager"]
      },
      "workflow": [
        "Supervision Consultant raises NCR",
        "Contractor acknowledges and proposes disposition",
        "PMC QA/QC reviews disposition",
        "PMC Delivery Manager signs off",
        "Employer's Representative approves",
        "Contractor implements corrective action",
        "Supervision Consultant verifies closure",
        "NCR closed"
      ],
      "statuses": ["RAISED", "ACKNOWLEDGED", "DISPOSITION_PROPOSED", "DISPOSITION_REVIEWED", "APPROVED", "IMPLEMENTING", "VERIFYING", "CLOSED"]
    },

    "PRC-403": {
      "title": "Testing & Commissioning",
      "category": "quality",
      "purpose": "Define testing and commissioning process per contract requirements",
      "scopes": {
        "rides": {
          "performer": "Vendor",
          "witness": "PMC Rides Director/Manager",
          "approver": "Independent Certifier"
        },
        "mep_infrastructure_building": {
          "performer": "Contractor",
          "witness": ["Supervision Consultant", "PMC"],
          "approver": "Supervision Consultant"
        }
      },
      "test_statuses": ["PASS", "FAIL", "CONDITIONAL_PASS", "PENDING_WITNESSING"],
      "hold_point_types": {
        "WITNESS_POINT": "PMC/SC must witness. Work may NOT proceed without witnessing.",
        "HOLD_POINT": "Requires explicit release by all signatories.",
        "REVIEW_POINT": "Documentation review only. Work may proceed after review."
      },
      "rules": [
        "Failed tests automatically generate punch list items",
        "Un-witnessed witness points must be escalated to PMC"
      ]
    },

    "PRC-404": {
      "title": "Handover Procedure",
      "category": "quality",
      "purpose": "Formal handover of completed works from Contractor to Employer",
      "prerequisites": [
        "All T&C complete with passing results (PRC-403)",
        "All NCRs closed (PRC-402)",
        "All punch list items cleared",
        "As-built drawings issued",
        "O&M manuals submitted",
        "Training completed",
        "Warranties and guarantees issued"
      ],
      "handover_documents": [
        "Certificate of Practical Completion (CPC)",
        "Defects Liability Period (DLP) start date",
        "Final snag list",
        "Handover register signed by all parties"
      ]
    },

    "PRC-405": {
      "title": "Construction Inspection Procedure",
      "category": "quality",
      "purpose": "Process for Contractor Inspection Requests",
      "document_prefix": "IR",
      "document_format": "IR-{4d}",
      "notice_periods": {
        "standard": "24 hours minimum",
        "structural_hold_point": "48 hours minimum"
      },
      "result_options": ["ACCEPTED", "REJECTED", "CONDITIONAL"],
      "result_rules": {
        "REJECTED": "Contractor must re-submit IR",
        "CONDITIONAL": "NCR raised under PRC-402"
      },
      "roles": {
        "process_owner": "PMC Delivery Manager",
        "initiator": "Contractor",
        "signatory": "Supervision Consultant",
        "approver": "Employer's Representative"
      }
    },

    "PRC-406": {
      "title": "HSE Audit and Inspection Procedure",
      "category": "hse",
      "purpose": "HSE audits and inspections across the project",
      "cadence": {
        "inspections": "Monthly",
        "formal_audits": "Quarterly"
      },
      "risk_categories": ["FATALITY_RISK", "SERIOUS_INJURY_RISK", "MINOR_INJURY_RISK", "ENVIRONMENTAL", "NEAR_MISS"],
      "stop_work": {
        "who_can_issue": "Any team member",
        "trigger": "Immediate life-safety risk",
        "resumption_authority": "PMC Project Director written sign-off required"
      }
    },

    "PRC-501": {
      "title": "Design Reviews & Acceptance",
      "category": "design",
      "purpose": "Review, comment, and accept design documentation",
      "review_statuses": {
        "FOR_COMMENT": "Reviewer marks up and issues comments. PMT Design Manager coordinates.",
        "ACCEPTANCE": "Employer satisfied design meets value expectations.",
        "BUY_OFF": "Equivalent to Acceptance for creative elements."
      },
      "forbidden_term": "APPROVED - never use this word on design documents",
      "timeline": {
        "min_distribution_days": 7,
        "max_distribution_days": 14,
        "workshop_duration_days": "1-2"
      },
      "templates": {
        "TEM-501": "Design Review Schedule",
        "TEM-502": "Design Review Comments Schedule",
        "TEM-503": "Roles & Responsibility Matrix",
        "TEM-504": "Design Package Acceptance Form",
        "TEM-505": "Project Decision Note (PDN)",
        "TEM-506": "Design Coordination Meeting Sample",
        "TEM-507": "Generic Design Progress Evaluation",
        "TEM-508": "DM Exceptions Justification Report",
        "TEM-509": "Workshop Design Decision Approval Form",
        "TEM-510": "Design Directive PMWeb Form"
      },
      "acceptance_forms": {
        "standard": "TEM-504",
        "decision_note": "TEM-505",
        "workshop": "TEM-509"
      },
      "workflow": [
        "PMT prepares Design Review Schedule (TEM-501)",
        "Designer issues Design Package (min 7 cal days before workshop)",
        "All reviewers prepare marked-up sets independently",
        "Design Review Workshop (1-2 days): Creative Consultant leads creative; PMT leads technical/commercial",
        "Compile & distribute Design Review Comments (TEM-502)",
        "Designer amends design per agreed comments",
        "PMT reviews and recommends acceptance",
        "Employer signs Design Package Acceptance Form (TEM-504)",
        "Issue for IP Review & Approvals"
      ],
      "raci": {
        "Employer": {"code": "A", "meaning": "Acceptance authority"},
        "PMT": {"code": "P/PR", "meaning": "Preparation and Primary Review"},
        "Creative Consultant": {"code": "PR", "meaning": "Primary Review on creative elements"},
        "Cost Consultant": {"code": "C", "meaning": "Comment"},
        "Operator": {"code": "C", "meaning": "Comment"},
        "Statutory Bodies / 3rd Party Inspector": {"code": "I", "meaning": "Informed"},
        "Turnkey Contractor": {"code": "P", "meaning": "Preparation"},
        "3rd Party Contractors / Suppliers": {"code": "P", "meaning": "Preparation"}
      },
      "design_phases": ["General/All Phases", "Feasibility", "Concept Design", "Schematic Design", "Detailed Design", "Construction Documents"]
    },

    "PRC-502": {
      "title": "Design Directives",
      "category": "design",
      "purpose": "Formal instructions from PMT to Contractor/Consultant for design changes",
      "document_prefix": "DD",
      "document_format": "DD-{3d}",
      "key_rule": "A DD does NOT constitute a Variation Settlement or Variation Order",
      "critical_rule": "No work on any instruction may proceed until the DD has Employer approval",
      "roles": {
        "authorizer": "Project Director",
        "implementer": "Head of Design Management",
        "executor": "Delivery Manager(s)"
      },
      "integration": "Must be used alongside PRC-606 (Change Management) when scope or cost is affected"
    },

    "PRC-601": {
      "title": "Tendering - Job Requisition and Prequalifications",
      "category": "procurement",
      "purpose": "Obtain Job Requisition Number and issue Request for Proposal",
      "document_prefix": "JR",
      "document_format": "JR-{4d}",
      "roles": {
        "authorizer": "Project Director",
        "co_authorizer": "Employer's Representative",
        "implementer": "Head of Contracts & Procurement",
        "executor": "Contracts Manager"
      }
    },

    "PRC-602": {
      "title": "Tendering - Request for Proposals",
      "category": "procurement",
      "purpose": "Issue formal tenders to prequalified contractors/consultants",
      "rfp_required_components": [
        "Instructions to Tenderers",
        "Scope of Work / Technical Specification",
        "Contract Conditions (draft)",
        "Drawings and Design Information",
        "Form of Tender",
        "Bill of Quantities or Schedule of Rates",
        "Compliance Schedules"
      ]
    },

    "PRC-603": {
      "title": "Tendering - Tender Analysis and Recommendation",
      "category": "procurement",
      "purpose": "Evaluate tender submissions and recommend contract award",
      "evaluation_criteria": {
        "technical": {"weight_min": 0.40, "weight_max": 0.50, "components": ["methodology", "programme", "resources"]},
        "commercial": {"weight_min": 0.40, "weight_max": 0.50, "components": ["price", "schedule_of_rates"]},
        "hse": {"weight_min": 0.05, "weight_max": 0.10},
        "local_content_sustainability": {"weight_min": 0.0, "weight_max": 0.10}
      },
      "deliverable": "Tender Evaluation Report (TER) with scored matrix and recommendation",
      "rap_variant": "PRC-603A - Rapid Approval Process for below-threshold awards"
    },

    "PRC-604": {
      "title": "Tendering - Approval and Contract Award",
      "category": "procurement",
      "purpose": "Formal approval and contract award",
      "award_package": ["Letter of Award (LOA)", "Signed Contract", "Performance Bond", "Advance Payment Bond", "Insurance certificates"],
      "approval_levels": {
        "below_threshold": "Delivery Manager",
        "above_threshold": "Project Director + Employer's Representative",
        "major_threshold": "Board level"
      }
    },

    "PRC-605": {
      "title": "Interim Payments",
      "category": "commercial",
      "purpose": "Processing contractor and consultant payment requests",
      "document_prefix": "PR",
      "document_format": "PR-{4d}",
      "pr_components": [
        "Payment Request Form (main)",
        "Back-up Calculation Sheet",
        "Checklist of Back-up Documents"
      ],
      "workflow": [
        "Contractor/Consultant submits PR",
        "Contracts Manager checks completeness",
        "Delivery Manager certifies value",
        "QA/QC Manager certifies quality compliance",
        "Head C&P recommends",
        "Project Director signs",
        "Employer's Representative approves",
        "Finance processes payment within contractual period"
      ],
      "retention": {
        "typical_rate": "5-10%",
        "release_50pct": "At Practical Completion",
        "release_100pct": "At end of Defects Liability Period (DLP)"
      },
      "rules": [
        "Payment Request Form is a controlled document - cannot be modified without VP Programme Management approval",
        "All PRs must be registered through Document Control",
        "Disputed amounts must be identified separately",
        "Undisputed portion must be paid on time regardless of disputes"
      ]
    },

    "PRC-606": {
      "title": "Change Management",
      "category": "commercial",
      "purpose": "Control scope, price, and programme changes",
      "document_prefix": "RFM",
      "document_format": "RFM-{3d}",
      "definitions": {
        "RFM": "Request for Modification - PMT instruction to Contractor. Does NOT constitute a VO.",
        "PSD": "Provisional Sum Directive - instructs use of provisional sum.",
        "Variation Settlement": "Agreed final value for a change.",
        "Variation Order": "Signed contract amendment formalizing an agreed change."
      },
      "change_types": {
        "Type_A": "Owner-initiated change (scope increase/decrease)",
        "Type_B": "Contractor-claimed variation (unforeseen condition, ambiguity)",
        "Type_C": "Regulatory or statutory change"
      },
      "roles": {
        "authorizer": "Director of Contracts & Procurement",
        "reviewer": "Sr. Administration Manager",
        "executor": "Delivery Manager",
        "contract_administrator": "Contract Manager/Administrator"
      },
      "workflow_type_a": [
        "Employer or PMT identifies change requirement",
        "Delivery Manager issues RFM to Contractor",
        "Contractor submits variation estimate (time + cost)",
        "PMC evaluates reasonableness",
        "Negotiation and agreement",
        "Variation Settlement agreed",
        "Project Director + Employer sign Variation Order",
        "Contract account updated",
        "Planning notified for programme impact"
      ],
      "integration": "Changes affecting design direction must also trigger a Design Directive (DD) under PRC-502",
      "critical_rule": "An RFM is an instruction - only a signed Variation Order (VO) changes the contract"
    }
  },

  "document_numbering": {
    "RFI": "RFI-{:04d}",
    "NCR": "NCR-{year}-{:03d}",
    "IR": "IR-{:04d}",
    "VO": "VO-{:03d}",
    "RFM": "RFM-{:03d}",
    "JR": "JR-{:04d}",
    "PDN": "PDN-{year}-{:03d}",
    "DD": "DD-{:03d}",
    "PR": "PR-{:04d}"
  },

  "forbidden_terms": {
    "design_approval": {
      "forbidden": "APPROVED",
      "correct_alternatives": ["accepted", "for comment", "buy-off"],
      "reason": "Contractually prohibited on design documents per PRC-501"
    }
  }
}
