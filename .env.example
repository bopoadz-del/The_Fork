# Cerebrum Blocks - Environment Variables
# Copy this file to .env and fill in your values

# ===============================
# AI Provider Keys
# ===============================
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ===============================
# Security
# ===============================
# Master key for admin auth operations (generate a strong random string)
CEREBRUM_MASTER_KEY=your_strong_random_master_key_here

# Comma-separated list of allowed CORS origins (no spaces)
# Leave empty to use safe defaults
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ===============================
# Storage
# ===============================
# Directory for uploaded files and persistent data
DATA_DIR=./data

# ===============================
# API Configuration
# ===============================
# Public base URL for generated file links
API_BASE_URL=http://localhost:8000

# Max upload size in bytes (default: 10MB)
MAX_UPLOAD_SIZE=10485760

# ===============================
# Deployment
# ===============================
ENV=production
PORT=8000

# ===============================
# Chat Stream Timeout + Heartbeat (FOLLOW-UP #92)
# ===============================
# Wall-clock cap on agent chat_stream — server emits a structured timeout
# error if the stream is still running after this many seconds.
CHAT_STREAM_TIMEOUT_SECONDS=90
# Heartbeat interval: server pushes {"type": "heartbeat"} after this many
# seconds of silence so frontend reader-deadlines can distinguish a slow
# LLM from a dead connection. Must be less than CHAT_STREAM_TIMEOUT_SECONDS.
CHAT_STREAM_HEARTBEAT_SECONDS=15

# ===============================
# Evidence Vault
# ===============================
EVIDENCE_VAULT_PATH=/tmp/cerebrum_evidence_vault.json

# ===============================
# ML / Learning Engine Storage
# ===============================
LEARNING_ENGINE_STORAGE=/tmp/cerebrum_learning_engine.json

# ===============================
# OCR (FOLLOW-UP #93)
# ===============================
# Tesseract language code(s). Default 'eng'. Set to 'ara+eng' for projects
# with Arabic content (e.g. KSA tender BOQs) — requires tesseract-ocr-ara
# in the Docker image (added in the same commit).
RAG_OCR_LANG=eng

# ===============================
# Grounded LoRA Adapter (Tinker)
# ===============================
# Flag-gated routing for the RAG-grounded LoRA adapter trained on
# data/learning/training_scenarios_rag_grounded.jsonl. When ENABLED is
# truthy AND TINKER_PATH is set AND TINKER_API_KEY is present, the chat
# block routes its inference through the adapter; any failure falls back
# to the existing Ollama path so this is one-toggle rollback.
GROUNDED_ADAPTER_ENABLED=false
GROUNDED_ADAPTER_TINKER_PATH=
GROUNDED_ADAPTER_TIMEOUT=60
# Reserved knob for the broad rewrite-pass path (post-Ollama re-grounding
# of tool-free responses). Not implemented yet; honoured only when its
# code lands. Explicit opt-in only — keep this false on every deploy
# until you have proved the narrow path serves correctly.
GROUNDED_ADAPTER_REWRITE_PASS=false
