# Cerebrum Blocks - Environment Variables
# Copy this file to .env and fill in your values

# ===============================
# AI Provider Keys
# ===============================
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ===============================
# Security
# ===============================
# Master key for admin auth operations (generate a strong random string)
CEREBRUM_MASTER_KEY=your_strong_random_master_key_here

# Comma-separated list of allowed CORS origins (no spaces)
# Leave empty to use safe defaults
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ===============================
# Storage
# ===============================
# Directory for uploaded files and persistent data (uploads, audit.log, etc.)
DATA_DIR=./data

# Unified SQLAlchemy database. When unset, stores use sqlite:///{DATA_DIR}/the_fork.db.
# Production pilot: provision Postgres 16 + pgvector and run `alembic upgrade head`.
# DATABASE_URL=postgresql+psycopg://thefork:thefork@localhost:5432/thefork

# ===============================
# Block registry boot profile
# ===============================
# Virgin boot (default): ~17 generic blocks only.
# CEREBRUM_VIRGIN=false loads extended platform blocks (drives, MCP, etc.).
# CEREBRUM_DOMAIN_KITS=construction loads the construction kit.
# Production Fork: CEREBRUM_VIRGIN=false and CEREBRUM_DOMAIN_KITS=construction
# CEREBRUM_VIRGIN=true
# CEREBRUM_DOMAIN_KITS=construction

# ===============================
# API Configuration
# ===============================
# Public base URL for generated file links
API_BASE_URL=http://localhost:8000

# Max upload size in bytes (default: 10MB)
MAX_UPLOAD_SIZE=10485760

# ===============================
# Deployment
# ===============================
ENV=production
PORT=8000

# ===============================
# Multi-worker (Redis + rate limits)
# ===============================
# When set, session state and per-caller rate limits are stored in Redis so
# multiple uvicorn workers share one budget. start.sh / entrypoint.sh use
# --workers 2 when this is present, else --workers 1.
# REDIS_URL=redis://localhost:6379/0

# Project session TTL in seconds (default 14400 = 4 hours). Applies to both
# in-memory and Redis session stores.
# SESSION_TTL_SECONDS=14400

# Global per-identity request cap per 60s sliding window (default 300).
# Set to 0 to disable. JWT user id, API key hash, or client IP is the identity.
# RATE_LIMIT_PER_MINUTE=300

# ===============================
# Error tracking (Sentry)
# ===============================
# When set, unhandled exceptions and 5xx responses are reported to Sentry.
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ===============================
# Chat Stream Timeout + Heartbeat (FOLLOW-UP #92)
# ===============================
# Wall-clock cap on agent chat_stream — server emits a structured timeout
# error if the stream is still running after this many seconds.
CHAT_STREAM_TIMEOUT_SECONDS=90
# Heartbeat interval: server pushes {"type": "heartbeat"} after this many
# seconds of silence so frontend reader-deadlines can distinguish a slow
# LLM from a dead connection. Must be less than CHAT_STREAM_TIMEOUT_SECONDS.
CHAT_STREAM_HEARTBEAT_SECONDS=15

# ===============================
# Evidence Vault
# ===============================
EVIDENCE_VAULT_PATH=/tmp/cerebrum_evidence_vault.json

# ===============================
# ML / Learning Engine Storage
# ===============================
LEARNING_ENGINE_STORAGE=/tmp/cerebrum_learning_engine.json

# ===============================
# OCR (FOLLOW-UP #93)
# ===============================
# Tesseract language code(s). Default 'eng'. Set to 'ara+eng' for projects
# with Arabic content (e.g. KSA tender BOQs) — requires tesseract-ocr-ara
# in the Docker image (added in the same commit).
RAG_OCR_LANG=eng

# ===============================
# Grounded LoRA Adapter (Tinker)
# ===============================
# Flag-gated routing for the RAG-grounded LoRA adapter trained on
# data/learning/training_scenarios_rag_grounded.jsonl. When ENABLED is
# truthy AND TINKER_PATH is set AND TINKER_API_KEY is present, the chat
# block routes its inference through the adapter; any failure falls back
# to the existing Ollama path so this is one-toggle rollback.
GROUNDED_ADAPTER_ENABLED=false
GROUNDED_ADAPTER_TINKER_PATH=
GROUNDED_ADAPTER_TIMEOUT=60
# Broad rewrite-pass: when true, the agent runtime re-grounds every
# tool-free cloud-provider response through the Tinker LoRA adapter
# (extra HTTP leg, hard 5s timeout, falls back to original on any
# failure). Requires GROUNDED_ADAPTER_ENABLED=true and a configured
# sampler-weights path; otherwise this flag is a no-op. Default off.
GROUNDED_ADAPTER_REWRITE_PASS=false
