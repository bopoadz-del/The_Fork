# The Fork — environment variables reference
# Copy this file to .env and fill in real values for your environment.
#
# Three profiles are noted below for each variable:
#   - REQUIRED-PROD  : production deploy refuses to start without it (or
#                      degrades silently in a way you don't want)
#   - RECOMMENDED    : safe defaults exist but you should set explicitly
#   - OPTIONAL       : feature flags / overrides
#
# Production guard: app/main.py::_validate_startup_env hard-fails the
# process at boot if ENV=production and SECRET_KEY is unset. Other
# REQUIRED-PROD variables only warn — set them anyway.

# ===============================
# Security (REQUIRED-PROD)
# ===============================

# JWT signing secret. Required for production. Tokens are invalidated
# whenever this value changes, so generate ONCE and store somewhere
# durable (env var on the host, secret manager — not the volume only).
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Fernet key for encryption-at-rest of uploaded documents. WITHOUT THIS,
# uploads land on disk as plaintext — a P0 confidentiality break for any
# client document corpus. The startup guard warns but does not fail.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DATA_ENCRYPTION_KEY=

# Master key for admin auth + the /v1/admin/* endpoints (CEREBRUM_MASTER_KEY
# is the legacy name still read by the auth layer). Treat as a root secret.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
CEREBRUM_MASTER_KEY=

# Comma-separated CORS origins (no spaces). Leave empty to use safe
# defaults. Production: list your real frontend origins explicitly.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ===============================
# Persistence (REQUIRED-PROD)
# ===============================

# Unified SQLAlchemy database. When unset, ALL stores fall back to
# sqlite:///{DATA_DIR}/the_fork.db — fine for local dev, NEVER for prod.
# Production pilot: provision Postgres 16 + pgvector and run
# `alembic upgrade head` before first boot.
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/thefork

# Directory for uploaded files, .secret_key fallback, audit.log,
# vector store fallback, learning state, OAuth refresh tokens, and
# every other file-backed artifact. Treat as a precious volume —
# disk loss without backup = permanent loss of the client corpus.
# See docs/backup-and-recovery.md for the snapshot + recovery procedure.
DATA_DIR=./data

# Shared cache + cross-worker session store + rate-limit budget. When
# unset, sessions / rate limits are per-process — fine for
# UVICORN_WORKERS=1, broken for any horizontal scaling. Required if you
# bump UVICORN_WORKERS > 1 or add a second instance.
REDIS_URL=redis://USER:PASSWORD@HOST:6379/0

# ===============================
# Bootstrap admin (REQUIRED-PROD on first boot only)
# ===============================
# Idempotent: app.main creates this user once at startup if no admin
# exists. After first boot you can rotate the password and leave the
# env unset (the existing admin row in the DB is what matters).
BOOTSTRAP_USER_EMAIL=
BOOTSTRAP_USER_PASSWORD=

# ===============================
# Observability (RECOMMENDED)
# ===============================

# Sentry DSN — when set, unhandled exceptions and 5xx responses are
# reported. Without it the platform is dark on errors past the local
# /v1/metrics (in-memory, resets every restart, per-worker).
SENTRY_DSN=

# ===============================
# Block registry boot profile
# ===============================
# CEREBRUM_VIRGIN=true   loads ~17 generic blocks only (minimal Fork).
# CEREBRUM_VIRGIN=false  loads extended platform blocks (drives, MCP, etc.).
# CEREBRUM_DOMAIN_KITS=construction loads the construction kit.
# Production Fork: CEREBRUM_VIRGIN=false AND CEREBRUM_DOMAIN_KITS=construction.
CEREBRUM_VIRGIN=false
CEREBRUM_DOMAIN_KITS=construction

# ===============================
# AI provider keys (set what you use)
# ===============================
# Primary LLM key. Today the chat path routes through Ollama Cloud via
# a cloudflared tunnel; DeepSeek is only used by select blocks.
DEEPSEEK_API_KEY=

# Tinker (LoRA fine-tuning) — used by training scripts + the grounded
# adapter rewrite path. Optional.
TINKER_API_KEY=

# ===============================
# Deployment
# ===============================

# `production` flips the startup guard ON (hard-fails missing SECRET_KEY).
# `development` skips the guard and accepts more permissive defaults.
# Match this to the environment you're actually running.
ENV=development

# HTTP port the FastAPI app binds. Render sets this for you.
PORT=8000

# Public base URL used to construct generated file links in responses.
API_BASE_URL=http://localhost:8000

# Max upload size in bytes (default 10MB).
MAX_UPLOAD_SIZE=10485760

# ===============================
# Process model
# ===============================
# UVICORN_WORKERS is the ONLY knob for uvicorn --workers (default 1).
# Render starter (512Mi): keep at 1; model2vec OOMs with 2 workers.
# Bumping above 1 REQUIRES REDIS_URL (cross-worker session + rate-limit
# state) AND a leader lock on hydration_scheduler — see audit P1.4.
UVICORN_WORKERS=1

# Session TTL applied to both in-memory and Redis session stores
# (default 14400 = 4 hours).
SESSION_TTL_SECONDS=14400

# Global per-identity request cap per 60s sliding window (default 300).
# Set to 0 to disable. JWT user id, API key hash, or client IP is the identity.
RATE_LIMIT_PER_MINUTE=300

# ===============================
# Chat streaming
# ===============================
# Wall-clock cap on agent chat_stream — server emits a structured timeout
# error if the stream is still running after this many seconds.
CHAT_STREAM_TIMEOUT_SECONDS=90

# Heartbeat interval: server pushes {"type": "heartbeat"} after this many
# seconds of silence so frontend reader-deadlines can distinguish a slow
# LLM from a dead connection. Must be less than CHAT_STREAM_TIMEOUT_SECONDS.
CHAT_STREAM_HEARTBEAT_SECONDS=15

# ===============================
# Evidence vault + learning engine
# ===============================
# DO NOT default these to /tmp on Render — /tmp is wiped on restart,
# which silently loses the evidence trail and learning state. Point
# both under DATA_DIR so they ride on the snapshotted volume.
EVIDENCE_VAULT_PATH=./data/evidence_vault.json
LEARNING_ENGINE_STORAGE=./data/learning_engine.json

# ===============================
# RAG embeddings (retrieval)
# ===============================
# Slim Render image: leave unset (defaults to model2vec minishlab/potion-base-8M,
# 256-dim — matches Postgres vector(256)). Do NOT set sentence-transformers unless
# you also migrate chunks.embedding to vector(384).
# RAG_EMBEDDING_MODEL=minishlab/potion-base-8M
# Tests / CI: RAG_EMBEDDING_MODEL=fake

# ===============================
# OCR
# ===============================
# Tesseract language code(s). Default 'eng'. Set to 'ara+eng' for projects
# with Arabic content (e.g. KSA tender BOQs) — requires tesseract-ocr-ara
# in the Docker image.
RAG_OCR_LANG=eng

# ===============================
# Grounded LoRA adapter (Tinker — OPTIONAL)
# ===============================
# Flag-gated routing for the RAG-grounded LoRA adapter. When ENABLED is
# truthy AND TINKER_PATH is set AND TINKER_API_KEY is present, the chat
# block routes inference through the adapter; any failure falls back to
# the existing Ollama path so this is one-toggle rollback.
GROUNDED_ADAPTER_ENABLED=false
GROUNDED_ADAPTER_TINKER_PATH=
GROUNDED_ADAPTER_TIMEOUT=60

# Broad rewrite-pass: when true, the agent runtime re-grounds every
# tool-free cloud-provider response through the Tinker LoRA adapter
# (extra HTTP leg, hard 5s timeout, falls back to original on any
# failure). Requires GROUNDED_ADAPTER_ENABLED=true. Default off.
GROUNDED_ADAPTER_REWRITE_PASS=false
