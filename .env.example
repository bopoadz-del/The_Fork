# Cerebrum Blocks - Environment Variables
# Copy this file to .env and fill in your values

# ===============================
# AI Provider Keys
# ===============================
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ===============================
# Security
# ===============================
# Master key for admin auth operations (generate a strong random string)
CEREBRUM_MASTER_KEY=your_strong_random_master_key_here

# Comma-separated list of allowed CORS origins (no spaces)
# Leave empty to use safe defaults
CORS_ORIGINS=https://your-domain.com,https://your-app.onrender.com

# ===============================
# Storage
# ===============================
# Directory for uploaded files and persistent data
DATA_DIR=./data

# ===============================
# API Configuration
# ===============================
# Public base URL for generated file links
API_BASE_URL=https://your-api.onrender.com

# Max upload size in bytes (default: 10MB)
MAX_UPLOAD_SIZE=10485760

# ===============================
# Deployment
# ===============================
ENV=production
PORT=8000

# ===============================
# Telegram Bot
# ===============================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ===============================
# Evidence Vault
# ===============================
EVIDENCE_VAULT_PATH=/tmp/cerebrum_evidence_vault.json

# ===============================
# ML / Learning Engine Storage
# ===============================
LEARNING_ENGINE_STORAGE=/tmp/cerebrum_learning_engine.json
