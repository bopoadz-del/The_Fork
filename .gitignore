# Secrets vault (plaintext removed - see vault/secrets.tar.gz.gpg)
.ssh/
.render/

vault/secrets.tar.gz
claudebot/KEYS.md

# Claude Code local settings (personal, machine-specific)
.claude/settings.local.json

# Runtime data directory at repo root (uploads, SQLite DB, audit log).
# Anchored with leading slash so app/data/ (versioned content like the
# procedures DB) is NOT swept up by this rule.
/data/
# ...except the Safety Observation AI v2 weights -- those ARE shipped.
!/data/models/
!/data/models/safety_world_v2.onnx
.playwright-mcp/

# wrangler / Cloudflare Workers local state
.wrangler
.dev.vars*
!.dev.vars.example

# Dead Chroma vector DB directory (PR #98 — Chroma never wired in app/;
# unified retriever is pgvector via app.core.rag.vector_store). Block
# accidental re-commit of any local chroma scratch files.
data/chroma_db/

# YOLO base/scratch artifacts (local-only). The BAKED .onnx we ship
# lives at data/models/safety_world_v2.onnx and IS committed via the
# /data/models/ exception above.
/runs/
/yolov8n.pt
/yolov8s-world.pt
/yolov8s-worldv2.pt
/yolov8m-worldv2.pt
/weights/
coverage.xml
