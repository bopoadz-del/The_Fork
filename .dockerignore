# Keep the build context (and image layers) lean — exclude VCS, virtualenvs,
# caches, dependency trees, local data, and CI files. Application source and
# requirements.txt are still copied in.
.git
.gitignore
.venv
venv
**/__pycache__
**/*.pyc
.pytest_cache
.mypy_cache
.ruff_cache
node_modules
frontend/node_modules
frontend/.vite
data
!data/models/safety_qaqc_v1_r4.pt
uploads
logs
*.log
tests/browser
.github
*.md
