{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "theshovel",
  "compatibility_date": "2026-06-14",
  "observability": {
    "enabled": true
  },
  "build": {
    "command": "npm ci && npm run build",
    "cwd": "frontend"
  },
  "assets": {
    "directory": "frontend/dist"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
